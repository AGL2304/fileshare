# Database
DATABASE_URL="postgresql://fileshare:fileshare_pass@localhost:5432/fileshare_db"

# JWT — use `openssl rand -base64 48` for production secrets
JWT_SECRET="change_me_in_production_use_a_long_random_string_at_least_32_chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
PORT=3001
NODE_ENV=development
# Comma-separated list of allowed origins
CORS_ORIGIN="http://localhost:5173"

# Storage
STORAGE_TYPE=local
STORAGE_LOCAL_PATH="./uploads"

# S3 (when STORAGE_TYPE=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-3
AWS_S3_BUCKET=

# Upload limits (100MB default)
MAX_FILE_SIZE_BYTES=104857600

# App URLs (used in share links and download URLs)
APP_URL="http://localhost:3001"
FRONTEND_URL="http://localhost:5173"

# Seed admin user (db:seed only)
ADMIN_EMAIL="admin@fileshare.local"
ADMIN_PASSWORD="Admin1234"
